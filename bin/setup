#!/usr/bin/env bash
set -eo pipefail

app_root="$(cd "$(dirname "$0")/.." && pwd)"
export PATH="$app_root/bin:$PATH"

step() {
  local step_name="$1"
  shift
  echo
  echo "▸ $step_name"
  "$@"
}

# Use mise to install Ruby if available, skip if Ruby is already present
if command -v mise &>/dev/null; then
  step "Installing Ruby" mise install --yes
  eval "$(mise hook-env -s bash)"
elif ! command -v ruby &>/dev/null; then
  echo "Ruby not found."
  echo
  echo "Options:"
  echo "  brew bundle          # installs Ruby + all dependencies from Brewfile"
  echo "  mise install         # if you use mise (https://mise.jdx.dev)"
  exit 1
fi

# Install system packages
if command -v brew &>/dev/null; then
  step "Installing dependencies" brew bundle
elif command -v apt-get &>/dev/null; then
  step "Installing packages" sudo apt-get update -qq && sudo apt-get install -y libpq-dev libvips-dev
fi

step "Installing gems" bundle install

if [[ $* == *--reset* ]]; then
  step "Resetting the database" bin/rails db:reset
else
  step "Preparing the database" bin/rails db:prepare
fi

step "Indexing products for search" bin/rails spree:search:reindex

step "Cleaning up" bin/rails log:clear tmp:clear

echo
echo "✓ Done (${SECONDS}s)"
echo
echo "Run 'bin/dev' to start the app."
