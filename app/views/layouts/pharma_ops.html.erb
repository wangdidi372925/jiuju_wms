<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <title>九州运营后台</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="pharma-page">
    <header class="pharma-topbar">
      <a class="pharma-brand" href="/pharma/ops">九州运营后台</a>
      <nav class="pharma-nav">
        <a href="/pharma/ops">看板</a>
        <a href="/pharma/ops/pharmacies">药店审核</a>
        <a href="/pharma/ops/catalog">货盘</a>
        <a href="/pharma/ops/suppliers">货盘方</a>
        <a href="/pharma/ops/supplier_offers">报价</a>
        <a href="/pharma/ops/orders">订单</a>
        <a href="/pharma/ops/fulfillments">履约</a>
      </nav>
      <div class="pharma-account">
        <% if defined?(current_admin_api_client) && current_admin_api_client.present? %>
          <span><%= current_admin_api_client.name %></span>
          <%= button_to "退出", "/pharma/ops/session", method: :delete, class: "pharma-link-button" %>
        <% end %>
      </div>
    </header>

    <main class="pharma-main">
      <% if notice.present? %>
        <div class="pharma-flash pharma-flash-notice"><%= notice %></div>
      <% end %>
      <% if alert.present? %>
        <div class="pharma-flash pharma-flash-alert"><%= alert %></div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
