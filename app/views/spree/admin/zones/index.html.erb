<%= content_for(:page_title) do %>
  <%= Spree.t(:zones) %>
<% end %>

<% content_for :page_actions do %>
  <%= render_admin_partials(:zones_actions_partials) %>
  <%= link_to_with_icon 'plus', Spree.t(:new_zone), new_object_url, class: 'btn btn-primary' if can? :create, Spree::Zone %>
<% end %>

<% content_for :page_alerts do %>
  <div class="alert alert-info">
    区域是国家或省州的地理分组，用于配送、税务和市场范围配置。
  </div>
<% end %>

<%= render_admin_partials(:zones_header_partials) %>

<%= render_table @collection, :zones %>
