<% content_for :page_title do %>
  <%= Spree.t(:shipping) %>
<% end %>

<% content_for :page_actions do %>
  <%= render_admin_partials(:shipping_methods_actions_partials) %>
  <%= link_to_with_icon 'plus', Spree.t(:new_shipping_method), new_object_url, class: 'btn btn-primary' if can?(:create, Spree::ShippingMethod) %>
<% end %>

<%= render partial: 'spree/admin/shared/shipping_nav' %>

<% content_for :page_alerts do %>
  <div class="alert alert-info">
    配送方式是药店结算时可选择的承运服务，用于控制商品如何配送到药店。
  </div>
<% end %>

<%= render_admin_partials(:shipping_methods_header_partials) %>

<%= render_table @collection, :shipping_methods %>
