<section class="pharma-heading-row">
  <div>
    <p class="pharma-kicker">导入详情</p>
    <h1><%= @import.original_filename %></h1>
  </div>
  <div class="pharma-action-row">
    <a class="pharma-secondary-button" href="/pharma/ops/inventory_imports">导入记录</a>
    <a class="pharma-primary-button" href="/pharma/ops/inventory_imports/new">继续上传</a>
  </div>
</section>

<section class="pharma-metrics">
  <div><span>状态</span><strong><%= @import.status %></strong></div>
  <div><span>成功行数</span><strong><%= @import.success_rows %> / <%= @import.total_rows %></strong></div>
  <div><span>失败行数</span><strong><%= @import.failed_rows %></strong></div>
</section>

<section class="pharma-panel">
  <div class="pharma-detail-grid">
    <div class="pharma-detail-item"><span>原始文件</span><strong><%= @import.original_filename %></strong></div>
    <div class="pharma-detail-item"><span>状态码</span><strong><%= @import.status %></strong></div>
    <div class="pharma-detail-item"><span>创建时间</span><strong><%= l @import.created_at, format: :short %></strong></div>
    <div class="pharma-detail-item"><span>更新时间</span><strong><%= l @import.updated_at, format: :short %></strong></div>
  </div>
</section>

<section class="pharma-table-wrap">
  <h2>错误明细</h2>
  <table class="pharma-table">
    <thead>
      <tr>
        <th>行号</th>
        <th>错误原因</th>
      </tr>
    </thead>
    <tbody>
      <% @import.error_details.each do |detail| %>
        <tr>
          <td><%= detail["row_number"] || detail[:row_number] || "-" %></td>
          <td><%= detail["message"] || detail[:message] %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <% if @import.error_details.blank? %>
    <div class="pharma-empty-state">没有错误行</div>
  <% end %>
</section>

<section class="pharma-table-wrap">
  <h2>最近货盘方</h2>
  <table class="pharma-table">
    <thead>
      <tr>
        <th>货盘方</th>
        <th>联系人</th>
        <th>区域</th>
        <th>状态</th>
      </tr>
    </thead>
    <tbody>
      <% @recent_suppliers.each do |supplier| %>
        <tr>
          <td><strong><%= supplier.name %></strong><span><%= supplier.code %></span></td>
          <td><%= supplier.contact_name %> / <%= supplier.contact_phone %></td>
          <td><%= [supplier.province, supplier.city].join(" ") %></td>
          <td><%= supplier.status %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <% if @recent_suppliers.blank? %>
    <div class="pharma-empty-state">暂无货盘方</div>
  <% end %>
</section>
