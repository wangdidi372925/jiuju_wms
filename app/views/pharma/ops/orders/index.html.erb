<section class="pharma-heading-row">
  <div>
    <p class="pharma-kicker">平台运营</p>
    <h1>订单列表</h1>
  </div>
</section>

<section class="pharma-table-wrap">
  <table class="pharma-table">
    <thead>
      <tr>
        <th>订单号</th>
        <th>药店</th>
        <th>状态</th>
        <th>金额</th>
        <th>提交时间</th>
        <th>操作</th>
      </tr>
    </thead>
    <tbody>
      <% @orders.each do |order| %>
        <% metadata = order.private_metadata || {} %>
        <tr>
          <td><%= order.number %></td>
          <td><%= metadata["pharmacy_name"] %><span><%= metadata["pharmacy_code"] %></span></td>
          <td><%= metadata["pharma_order_status"] || order.status %></td>
          <td><%= order.total %></td>
          <td><%= l(order.completed_at, format: :long) if order.completed_at.present? %></td>
          <td><a class="pharma-secondary-button" href="/pharma/ops/orders/<%= order.number %>">查看</a></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</section>
